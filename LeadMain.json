    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst total = items.length;\nconst high = items.filter(i => (i.json.score || 0) >= 7).length;\nconst moderate = items.filter(i => (i.json.score || 0) >= 5 && (i.json.score || 0) <= 6).length;\nconst low = items.filter(i => (i.json.score || 0) <= 4).length;\nconst escalated = items.filter(i => i.json.escalated === true).length;\n\nconst bySource = {};\nitems.forEach(i => {\n  const src = i.json.source || 'Unknown';\n  bySource[src] = (bySource[src] || 0) + 1;\n});\n\nconst sourceBreakdown = Object.entries(bySource)\n  .map(([src, count]) => `${src}: ${count}`)\n  .join('\\n');\n\nreturn [{\n  json: {\n    total,\n    high,\n    moderate,\n    low,\n    escalated,\n    sourceBreakdown\n  }\n}];"
      },
