    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// Skip if this item has no email (came from GetAllClients branch)\nif (!input.email) {\n  return [];\n}\n\nconst currentEmail = input.email.trim().toLowerCase();\nconst existingRows = $('GetAllClients').all();\n\nif (!existingRows || existingRows.length === 0) {\n  return [{ json: { ...input, isDuplicate: false } }];\n}\n\nconst isDuplicate = existingRows.some(item => {\n  const existingEmail = (item.json.email || item.json.Email || '').trim().toLowerCase();\n  return existingEmail === currentEmail && existingEmail !== '';\n});\n\nreturn [{ json: { ...input, isDuplicate } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
