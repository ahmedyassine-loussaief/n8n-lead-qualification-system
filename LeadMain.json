        "groqApi": {
          "id": "Lw1zp9uwfjYJFoVN",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.text || $input.item.json.output || '';\n\nconst matches = typeof raw === 'string' ? raw.match(/\\{[\\s\\S]*?\\}/g) : null;\n\nlet parsed = null;\n\nif (matches) {\n  for (let i = matches.length - 1; i >= 0; i--) {\n    try {\n      const candidate = JSON.parse(matches[i]);\n      if (candidate.score !== undefined && candidate.intent !== undefined && candidate.name !== undefined) {\n        parsed = candidate;\n        break;\n      }\n    } catch (e) {\n      continue;\n    }\n  }\n}\n\nif (!parsed) {\n  return {\n    json: {\n      error: true,\n      reason: 'parse_failed',\n      raw_output: raw\n    }\n  };\n}\n\nreturn {\n  json: {\n    name: parsed.name,\n    email: parsed.email,\n    source: parsed.source,\n    score: parsed.score,\n    intent: parsed.intent,\n    summary: parsed.summary\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
